# ============================================================
# Copie este arquivo para .env e preencha os valores.
# O .env NUNCA deve ir para o repositório (já está no .gitignore).
# ============================================================

# ---------- Banco de dados ----------
# Local (Docker): postgres://casa:casa_senha@db:5432/casa_temporada
# Produção (Coolify): Coolify gera esta URL automaticamente ao criar o banco
DATABASE_URL=postgres://usuario:senha@host:5432/casa_temporada

# ---------- Segurança ----------
# Gere tokens aleatórios: openssl rand -hex 32
CRON_SECRET=troque-por-token-aleatorio-forte
NEXT_PUBLIC_CRON_SECRET=troque-por-token-publico
AIRBNB_BLOCK_ICAL_SECRET=troque-por-token-ical-privado
NEXT_PUBLIC_AIRBNB_BLOCK_ICAL_SECRET=troque-por-token-ical-publico

# ---------- Airbnb iCal (sincronização de entrada) ----------
# Airbnb > Calendário > Disponibilidade > Sincronizar calendários > Exportar
AIRBNB_ICAL_URL=https://www.airbnb.com.br/calendar/ical/SEU_ID.ics?t=SEU_TOKEN

# ---------- WhatsApp Cloud API (Meta) ----------
# Sem credenciais, o envio roda em MODO SIMULADO (logs no console)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_API_VERSION=v20.0

# ---------- Dados da propriedade ----------
CASA_NOME=Casa de Temporada Olímpia
